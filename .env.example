VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Edge Function secrets. Set with `supabase secrets set ...`; do not expose
# secret database or model keys in frontend hosting variables.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Model-agnostic OpenAI-compatible gateway used by Supabase Edge Functions.
MODEL_BASE_URL=https://api.groq.com/openai/v1
MODEL_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile
MODEL_PROVIDER_LABEL=Groq

# Optional provider examples:
# MODEL_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=openrouter/auto
# MODEL_PROVIDER_LABEL=OpenRouter Auto
#
# MODEL_BASE_URL=http://127.0.0.1:4096/v1
# MODEL_NAME=opencode-managed-model
